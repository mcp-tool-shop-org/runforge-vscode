{
  "name": "runforge",
  "displayName": "RunForge — ML Training, Reproducible",
  "description": "Deterministic, contract-driven ML training inside VS Code. Same dataset, same seed, same version — identical model, every time. Run, browse, inspect — all in-editor.",
  "version": "1.2.1",
  "publisher": "mcp-tool-shop",
  "author": {
    "name": "mcp-tool-shop",
    "email": "64996768+mcp-tool-shop@users.noreply.github.com"
  },
  "icon": "assets/icon.png",
  "homepage": "https://github.com/mcp-tool-shop-org/runforge-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/runforge-vscode"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/runforge-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Data Science",
    "Notebooks"
  ],
  "keywords": [
    "machine learning",
    "ml training",
    "mlops",
    "reproducibility",
    "determinism",
    "experiment tracking",
    "sklearn",
    "scikit-learn",
    "data science",
    "python"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "license": "MIT",
  "contributes": {
    "commands": [
      {
        "command": "runforge.trainStandard",
        "title": "Train (Standard)",
        "category": "RunForge",
        "icon": "$(play)"
      },
      {
        "command": "runforge.trainHighQuality",
        "title": "Train (High Quality)",
        "category": "RunForge",
        "icon": "$(star)"
      },
      {
        "command": "runforge.openRuns",
        "title": "Open Runs",
        "category": "RunForge",
        "icon": "$(folder)"
      },
      {
        "command": "runforge.inspectDataset",
        "title": "Inspect Dataset",
        "category": "RunForge",
        "icon": "$(search)"
      },
      {
        "command": "runforge.openLatestMetadata",
        "title": "Open Latest Run Metadata",
        "category": "RunForge",
        "icon": "$(json)"
      },
      {
        "command": "runforge.inspectArtifact",
        "title": "Inspect Model Artifact",
        "category": "RunForge",
        "icon": "$(file-binary)"
      },
      {
        "command": "runforge.browseRuns",
        "title": "Browse Runs",
        "category": "RunForge",
        "icon": "$(list-unordered)"
      },
      {
        "command": "runforge.viewMetricsV1",
        "title": "View Latest Metrics",
        "category": "RunForge",
        "icon": "$(graph)"
      },
      {
        "command": "runforge.viewFeatureImportance",
        "title": "View Latest Feature Importance",
        "category": "RunForge",
        "icon": "$(list-ordered)"
      },
      {
        "command": "runforge.viewLinearCoefficients",
        "title": "View Latest Linear Coefficients",
        "category": "RunForge",
        "icon": "$(symbol-numeric)"
      },
      {
        "command": "runforge.viewInterpretabilityIndex",
        "title": "View Latest Interpretability Index",
        "category": "RunForge",
        "icon": "$(list-tree)"
      },
      {
        "command": "runforge.exportRunMarkdown",
        "title": "Export Latest Run as Markdown",
        "category": "RunForge",
        "icon": "$(markdown)"
      },
      {
        "command": "runforge.cancelActiveRun",
        "title": "Cancel Active Training",
        "category": "RunForge",
        "icon": "$(stop-circle)"
      },
      {
        "command": "runforge.recoverIndex",
        "title": "Recover Index",
        "category": "RunForge",
        "icon": "$(refresh)"
      }
    ],
    "configuration": [
      {
        "title": "RunForge: Python",
        "order": 1,
        "properties": {
          "runforge.pythonPath": {
            "type": "string",
            "default": "python",
            "scope": "machine",
            "order": 1,
            "markdownDescription": "Path to the Python executable used for training. Python 3.10+ is required. Examples: `/usr/bin/python3.11` or `C:\\Python311\\python.exe`. Leave as `python` to use whatever resolves on `PATH`."
          }
        }
      },
      {
        "title": "RunForge: Model",
        "order": 2,
        "properties": {
          "runforge.modelFamily": {
            "type": "string",
            "default": "logistic_regression",
            "order": 1,
            "enum": [
              "logistic_regression",
              "random_forest",
              "linear_svc"
            ],
            "markdownEnumDescriptions": [
              "**Logistic Regression** — fast, interpretable linear classifier. Good default for tabular data.",
              "**Random Forest** — ensemble of decision trees. Handles non-linear patterns; slower to train.",
              "**Linear SVC** — support vector classifier with linear kernel. Margin-based; competitive on high-dimensional data."
            ],
            "markdownDescription": "Which model family to train. May be overridden by `#runforge.profile#` (e.g. `thorough` forces Random Forest)."
          }
        }
      },
      {
        "title": "RunForge: Profile",
        "order": 3,
        "properties": {
          "runforge.profile": {
            "type": "string",
            "default": "",
            "order": 1,
            "enum": [
              "",
              "default",
              "fast",
              "thorough"
            ],
            "markdownEnumDescriptions": [
              "_(none)_ — use the preset's defaults.",
              "**Default** — preset defaults, no overrides.",
              "**Fast** — reduced iterations for quick iteration.",
              "**Thorough** — more trees/iterations; uses Random Forest regardless of `#runforge.modelFamily#`."
            ],
            "markdownDescription": "Training profile. Profiles can override `#runforge.modelFamily#` and hyperparameters."
          }
        }
      },
      {
        "title": "RunForge: Execution",
        "order": 4,
        "properties": {
          "runforge.datasetPath": {
            "type": "string",
            "default": "",
            "scope": "machine",
            "order": 1,
            "markdownDescription": "Absolute path to the dataset CSV used for training. Leave empty (default) to be prompted with a file picker on every run. When set, the training command validates that the file exists and aborts with an actionable error if it does not — no auto-detect, no fuzzy-match."
          }
        }
      },
      {
        "title": "RunForge: Advanced",
        "order": 99,
        "properties": {
          "runforge.mlRunnerModule": {
            "type": "string",
            "default": "ml_runner",
            "scope": "machine",
            "order": 1,
            "markdownDescription": "_Advanced._ Python module name to invoke (`python -m <module>`). Override only when running a custom runner. Default `ml_runner` ships with the extension."
          }
        }
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "runforge.cancelActiveRun", "when": "runforge:hasActiveRun" },
        { "command": "runforge.trainStandard", "when": "!runforge:hasActiveRun" },
        { "command": "runforge.trainHighQuality", "when": "!runforge:hasActiveRun" }
      ]
    },
    "keybindings": [
      {
        "command": "runforge.trainStandard",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "!runforge:hasActiveRun"
      },
      {
        "command": "runforge.cancelActiveRun",
        "key": "ctrl+alt+x",
        "mac": "cmd+alt+x",
        "when": "runforge:hasActiveRun"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts --rulesdir eslint-rules",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "compile:test": "tsc -p test/extension-host/tsconfig.json",
    "test:smoke": "npm run compile && npm run compile:test && vscode-test",
    "verify": "npm test && npm run lint && npm run compile && npx vsce package --no-dependencies",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.11",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
